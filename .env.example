NODE_ENV=production
JWT_SECRET=
DB_PASSWORD=
REDIS_PASSWORD=
ACME_EMAIL=admin@domain.com
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
API_PORT=3001
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://admin:${DB_PASSWORD}@db:5432/edgecontrol
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
TRAEFIK_DYNAMIC_CONFIG_PATH=/traefik-config/dynamic.yml
HEALTH_CHECK_INTERVAL_MS=10000
LATENCY_WARN_MS=800
LATENCY_CRIT_MS=2000
MAX_CONSECUTIVE_FAILURES=3
# When false, /metrics returns 403 if X-Forwarded-For is set (e.g. via Traefik); Prometheus scrapes directly.
METRICS_ALLOW_PUBLIC=false
# Docker Compose sets these on the API for dynamic Prometheus file_sd (see docker/prometheus/file_sd).
# PROMETHEUS_FILE_SD_PATH=/prometheus-sd/edgecontrol-services.json
# PROMETHEUS_RELOAD_URL=http://prometheus:9090/-/reload
WEBHOOK_ALERT_SECRET=
ADMIN_EMAIL=admin@edgecontrol.local
ADMIN_PASSWORD=ChangeMe123456!
RBAC_SEED_PASSWORD=ChangeMe123456!
RBAC_SUPER_ADMIN_EMAIL=superadmin@edgecontrol.local
RBAC_ADMIN_EMAIL=admin@edgecontrol.local
RBAC_DEVELOPER_EMAIL=developer@edgecontrol.local
RBAC_VIEWER_EMAIL=viewer@edgecontrol.local

# Grafana (docker compose — monitoring UI on host port 3010)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMeGrafana!
GRAFANA_ROOT_URL=http://localhost:3010

# MinIO — not published on host; Traefik terminates TLS by Host (Docker labels on minio service).
# Point DNS for both hostnames at this machine; ACME via Traefik (same as panel/API).
# Optional: if set, ./scripts/setup.sh fills MINIO_S3_DOMAIN, MINIO_CONSOLE_DOMAIN, and HTTPS URLs to match.
BASE_DOMAIN=
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=ChangeMeMinioRoot!
MINIO_BUCKET=edgecontrol
MINIO_S3_DOMAIN=s3.example.com
MINIO_CONSOLE_DOMAIN=minio.example.com
MINIO_SERVER_URL=https://s3.example.com
MINIO_BROWSER_REDIRECT_URL=https://minio.example.com
# Optional: must match `docker compose` project name for volume edgecontrol_minio_data (see scripts/backup.sh)
# COMPOSE_PROJECT_NAME=edgecontrol
# MINIO_BACKUP_VOLUME_NAME=edgecontrol_minio_data
