NODE_ENV=production
# JWT for the API container (minimum 32 characters).
JWT_SECRET=change_me_use_openssl_rand_hex_32_chars_minimum
# Postgres: used by the db service (POSTGRES_PASSWORD) and DATABASE_URL below. ./scripts/setup.sh fills this (openssl).
DB_PASSWORD=
ACME_EMAIL=admin@domain.com

# Traefik (HTTPS :443): defaults edgecontrol.<BASE_DOMAIN>, api.<BASE_DOMAIN>, s3.<BASE_DOMAIN>, minio.<BASE_DOMAIN>.
# Override with PANEL_HOST / API_HOST / MINIO_API_HOST / MINIO_CONSOLE_HOST when you do not use those subdomains.
# If BASE_DOMAIN is wrong or empty, Host() rules become invalid (e.g. Host(`minio.`) → Traefik 404). Prefer explicit hosts in production:
# MINIO_CONSOLE_HOST=minio.ptsi.co.id
# MINIO_API_HOST=s3.ptsi.co.id
#
# Shared external Docker network (e.g. name "proxy"): set TRAEFIK_DOCKER_NETWORK=proxy and run Compose with
#   docker compose -f docker-compose.yml -f docker-compose.proxy.yml up -d
# so Traefik’s Docker provider and traefik.docker.network labels match the same network.
# TRAEFIK_DOCKER_NETWORK=proxy
# Example: BASE_DOMAIN=ptsi.co.id → panel Host edgecontrol.ptsi.co.id unless PANEL_HOST is set.
# PANEL_HOST=edgecontrol.ptsi.co.id
# API_HOST=api.ptsi.co.id

# Panel + API: map host ports in docker-compose.yml (API_PUBLISH_PORT default 3001, PANEL 8080).
# The panel nginx proxies /trpc and /api to http://api:3000. Set CORS_ORIGIN to the panel origin the browser uses
# (e.g. https://edgecontrol.ptsi.co.id when you open the panel through Traefik, not only loopback).
# Optional (add only when needed): PUBLIC_API_URL for a custom web image API base; TELEGRAM_BOT_TOKEN,
# TELEGRAM_CHAT_ID; WEBHOOK_ALERT_SECRET (min 16 chars when set).
API_PUBLISH_PORT=3001
PANEL_PUBLISH_PORT=8080
CORS_ORIGIN=http://127.0.0.1:8080

# Apex domain hint for ACME_EMAIL derivation (admin@<BASE_DOMAIN>) and for managed proxy
# hostnames you add in the UI (Traefik still serves :80/:443 from dynamic.yml only).
# Let's Encrypt rejects reserved names like *.example.com for those managed routes.
BASE_DOMAIN=example.com

# Host-only tooling; the API container listens on 3000 inside Docker.
API_PORT=3001
DATABASE_URL=postgresql://admin:${DB_PASSWORD}@db:5432/edgecontrol
# Redis: bundled docker-compose runs Redis without auth on the internal network and sets REDIS_URL for API/worker to redis://redis:6379. This line is for tooling that reads .env only; compose overrides it for containers.
REDIS_URL=redis://redis:6379
TRAEFIK_DYNAMIC_CONFIG_PATH=/traefik-config/dynamic.yml
HEALTH_CHECK_INTERVAL_MS=10000
LATENCY_WARN_MS=800
LATENCY_CRIT_MS=2000
MAX_CONSECUTIVE_FAILURES=3
METRICS_ALLOW_PUBLIC=false
ADMIN_EMAIL=admin@edgecontrol.local
ADMIN_PASSWORD=ChangeMe123456!
RBAC_SEED_PASSWORD=ChangeMe123456!
RBAC_SUPER_ADMIN_EMAIL=superadmin@edgecontrol.local
RBAC_ADMIN_EMAIL=admin@edgecontrol.local
RBAC_DEVELOPER_EMAIL=developer@edgecontrol.local
RBAC_VIEWER_EMAIL=viewer@edgecontrol.local

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMeGrafana!
GRAFANA_ROOT_URL=http://localhost:3010

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=ChangeMeMinioRoot!
MINIO_BUCKET=edgecontrol
# After https://minio.<your-domain> routes correctly, set public URLs MinIO should advertise (scheme + host, no path):
# MINIO_BROWSER_REDIRECT_URL=https://minio.ptsi.co.id
# MINIO_SERVER_URL=https://s3.ptsi.co.id
